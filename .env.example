# ── Environment ────────────────────────────────────────────────────────────────
APP_ENV=dev                        # dev | prod  (controls /docs exposure)
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-for-demo      # REQUIRED: use a long random string in prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Observability ──────────────────────────────────────────────────────────────
METRICS_ENABLED=true               # true | false
METRICS_TOKEN=                     # optional: protects /metrics when set

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_BACKEND=postgresql        # postgresql | sqlite  (sqlite for local dev without Docker)
SQLITE_PATH=./service.db           # only used when DATABASE_BACKEND=sqlite

POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon
POSTGRES_DB=hackathon
# POSTGRES_HOST and POSTGRES_PORT are set per-service in docker-compose; override here if needed

# ── Service Discovery (used by the gateway) ────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8000
ITEM_SERVICE_URL=http://item-service:8000
AI_AGENT_SERVICE_URL=http://ai-agent-service:8000

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=3001

# ── Item Service ───────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── AI Agent Service ───────────────────────────────────────────────────────────
LLM_PROVIDER=mock                  # mock | openai | anthropic — replace for real LLM
MIN_RELEVANCE_SCORE=0.2            # 0.0–1.0: lower = more results, higher = stricter filtering
