# RentPi — copy to .env and fill in your values before running docker-compose
# Never commit .env — it is gitignored

# ── Environment ────────────────────────────────────────────────────────────────
APP_ENV=dev                        # dev | prod
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Security / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_something_long_and_random   # REQUIRED
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Observability ──────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_TOKEN=                     # optional: protects /metrics when set

# ── Central API ───────────────────────────────────────────────────────────────
CENTRAL_API_URL=https://technocracy.brittoo.xyz
CENTRAL_API_TOKEN=                 # REQUIRED: token given by judges
CENTRAL_API_RATE_LIMIT=20
CENTRAL_API_RATE_WINDOW_SECONDS=60
CENTRAL_API_REDIS_URL=redis://redis:6379/0

# ── Postgres (user-service) ───────────────────────────────────────────────────
DATABASE_BACKEND=postgresql
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon
POSTGRES_DB=hackathon

# ── MongoDB (agentic-service) ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/rentpi_agentic

# ── gRPC Service Addresses (gateway → downstream) ─────────────────────────────
USER_SERVICE_ADDR=user-service:50051
RENTAL_SERVICE_ADDR=rental-service:50052
ANALYTICS_SERVICE_ADDR=analytics-service:50053
AGENTIC_SERVICE_ADDR=agentic-service:50054

# ── AI Provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=mock                  # mock | gemini | openai | groq
MIN_RELEVANCE_SCORE=0.2
GEMINI_API_KEY=                    # recommended — free tier available
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Service Ports ──────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
FRONTEND_PORT=3000
